# ============================================================
# SECURITY: never commit secrets or credentials
# ============================================================
# Environment / dotenv files (commonly hold API keys)
.env
.env.*
!.env.example          # allow template file if you create one

# Cloud credentials
.aws/
.aws-credentials
credentials
credentials.json
config.json
*.credentials


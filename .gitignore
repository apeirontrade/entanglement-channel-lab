*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
id_dsa
id_dsa.*
known_hosts
authorized_keys

# Token / secret file patterns
*secret*
*_secret*
secrets.yaml
secrets.yml
secrets.toml
secrets.json
auth.json
token.txt
*.token

# API key drop files
api_keys.txt
api_keys.json
.apikey

# Braket / AWS task output caches
braket_output/
braket-output/

# Local IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OpenClaw workspace-local state (belt and suspenders)
.openclaw/
